generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  username  String
  name      String
  quantity  Float
  unit      String
  createdAt DateTime @default(now())

  @@index([username])
}
